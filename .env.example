# Common
FC_JWT_SECRET=replace-with-a-long-secret

# Unlock mode toggles (server)
FC_ENABLE_HOLDER_UNLOCK=true
FC_ENABLE_PAYMENT_UNLOCK=true
FC_DEFAULT_UNLOCK_METHOD=holder

# Solana holder verification (server-side)
FC_SOLANA_MINT_ADDRESS=YOUR_FC_TOKEN_MINT_ADDRESS
FC_HOLDER_THRESHOLD_PERCENT=1

# Solana payment verification (server-side)
FC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
FC_SOLANA_PAYMENT_ADDRESS=YOUR_SOLANA_RECEIVER_WALLET
FC_SOLANA_ACCESS_PRICE_SOL=5

# Public unlock mode config
NEXT_PUBLIC_FC_ENABLE_HOLDER_UNLOCK=true
NEXT_PUBLIC_FC_ENABLE_PAYMENT_UNLOCK=true
NEXT_PUBLIC_FC_DEFAULT_UNLOCK_METHOD=holder

# Public client config
NEXT_PUBLIC_FC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_FC_SOLANA_MINT_ADDRESS=YOUR_FC_TOKEN_MINT_ADDRESS
NEXT_PUBLIC_FC_SOLANA_PAYMENT_ADDRESS=YOUR_SOLANA_RECEIVER_WALLET
NEXT_PUBLIC_FC_ACCESS_PRICE_SOL=5

# Set false for local HTTP testing with next start
FC_COOKIE_SECURE=false

