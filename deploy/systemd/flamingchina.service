# /etc/systemd/system/flamingchina.service

[Unit]
Description=Flaming China Intelligence Portal (Next.js)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/flamingchina
Environment=NODE_ENV=production
Environment=PORT=3000
EnvironmentFile=/var/www/flamingchina/.env.production
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target